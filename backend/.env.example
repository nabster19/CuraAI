# Flask Configuration
FLASK_ENV=development
FLASK_APP=run.py
FLASK_DEBUG=True

# Database Configuration
DATABASE_HOST=localhost
DATABASE_PORT=3306
DATABASE_USER=root
DATABASE_PASSWORD=your_password
DATABASE_NAME=curaai
DATABASE_URL=mysql+pymysql://root:password@localhost/curaai

# JWT Configuration
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this
JWT_EXPIRATION_HOURS=24

# Security
BCRYPT_LOG_ROUNDS=12

# Twilio Configuration
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890
TWILIO_SMS_TO_NUMBERS=7795273241,7019113622

# File Upload
MAX_UPLOAD_SIZE_MB=50
UPLOAD_FOLDER=uploads
ALLOWED_EXTENSIONS=pdf,jpg,jpeg,png,tiff,bmp

# Tesseract OCR
TESSERACT_PATH=/usr/bin/tesseract

# API Configuration
API_HOST=0.0.0.0
API_PORT=5000
API_PREFIX=/api
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Machine Learning Models Path
ML_MODELS_PATH=app/ml_models

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/curaai.log

# Email (Optional)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM_EMAIL=noreply@curaai.com
